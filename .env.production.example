# Hectic Production Environment Configuration
# Copy this file to .env.production and fill in the values
# DO NOT COMMIT .env.production TO GIT!

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=production

# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
# Single DOMAIN variable auto-generates all subdomain URLs:
#   - https://hectic.io (public site)
#   - https://admin.hectic.io (admin panel)
#   - https://api.hectic.io (API endpoints)
#   - https://{tenant}.hectic.io (workspace portals)
DOMAIN=hectic.io

# =============================================================================
# SERVER
# =============================================================================
# NOTE: Do NOT set PORT in shared .env for blue/green systemd deployments.
# Slot-specific systemd units set PORT per slot (8080/8081).

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DATABASE_DSN=REQUIRED-postgres-connection-string
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m
DATABASE_CONN_MAX_IDLE_TIME=5m

# =============================================================================
# STORAGE (S3 or filesystem)
# =============================================================================
# Most production installs use s3 for attachments with local filesystem paths for ops data.
STORAGE_TYPE=s3
STORAGE_PATH=/opt/hectic/data

S3_REGION=ams3
S3_ENDPOINT=https://ams3.digitaloceanspaces.com
S3_ATTACHMENTS_BUCKET=hectic-attachments
# Optional app backup bucket usage
S3_BACKUPS_BUCKET=hectic-backups

# S3 Credentials (DigitalOcean Spaces or AWS)
AWS_ACCESS_KEY_ID=REQUIRED-your-production-spaces-access-key-id
AWS_SECRET_ACCESS_KEY=REQUIRED-your-production-spaces-secret-access-key

# Storage Encryption at Rest (optional)
STORAGE_ENCRYPTION_ENABLED=false
# STORAGE_ENCRYPTION_KEY=

# =============================================================================
# CACHE
# =============================================================================
CACHE_ENABLED=true
CACHE_TTL=1h

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# Generate with: openssl rand -base64 64
JWT_SECRET=REQUIRED-CRITICAL-generate-unique-production-jwt-secret-openssl-rand-base64-64
JWT_EXPIRY=168h
MAGIC_LINK_TTL=15m
INSTANCE_ID=REQUIRED-stable-production-instance-id
EXTENSION_TRUST_REQUIRE_VERIFICATION=true
# Trusted publishers for signed extension bundles.
# Example:
# EXTENSION_TRUSTED_PUBLISHERS_JSON={"demandops":{"ed25519:prod":"REPLACE_WITH_PUBLISHER_PUBLIC_KEY"}}
EXTENSION_TRUSTED_PUBLISHERS_JSON=REQUIRED-production-publisher-trust-json

# Cookie domain for cross-subdomain authentication
COOKIE_DOMAIN=.hectic.io

# Privileged identity provider policy
# Restrict enterprise-access to reviewed IdP hosts only.
# Wildcards may be used for subdomains, e.g. *.okta.com
ENTERPRISE_ACCESS_ALLOWED_HOSTS=REQUIRED-reviewed-idp-hosts-comma-separated
# Production should prefer secret-manager-backed refs and disable env: refs.
ENTERPRISE_ACCESS_ALLOW_ENV_SECRET_REFS=false

# =============================================================================
# EMAIL (Postmark recommended, SMTP/SES supported through adapters)
# =============================================================================
EMAIL_BACKEND=postmark
POSTMARK_SERVER_TOKEN=REQUIRED-your-postmark-production-server-token
POSTMARK_WEBHOOK_SECRET=REQUIRED-generate-random-webhook-secret-32-chars-production

# Optional alternate backends
# EMAIL_BACKEND=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your-user
# SMTP_PASSWORD=your-password
#
# EMAIL_BACKEND=ses
# SES_REGION=us-east-1
# SES_ACCESS_KEY=your-access-key
# SES_SECRET_KEY=your-secret-key

# Optional overrides (otherwise auto-generated from DOMAIN)
# FROM_EMAIL=noreply@hectic.io
# FROM_NAME=Hectic

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MIN=60

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090
METRICS_TOKEN=REQUIRED-generate-random-metrics-bearer-token
TRUSTED_PROXIES=127.0.0.1,::1

# Optional APM
# SENTRY_DSN=
# DATADOG_API_KEY=

# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
# [ ] All REQUIRED placeholders replaced
# [ ] JWT_SECRET is strong and unique
# [ ] DATABASE_DSN points to a reachable PostgreSQL instance
# [ ] PostgreSQL backup and retention are covered by the selected database provider or operator runbook
# [ ] POSTMARK tokens are set
# [ ] S3 credentials valid with least privilege
# [ ] S3_ATTACHMENTS_BUCKET exists
# [ ] METRICS_TOKEN is set
# [ ] INSTANCE_ID is set and stable across rollouts
# [ ] EXTENSION_TRUST_REQUIRE_VERIFICATION=true
# [ ] EXTENSION_TRUSTED_PUBLISHERS_JSON contains reviewed publisher keys
# [ ] ENTERPRISE_ACCESS_ALLOWED_HOSTS contains only approved IdP domains
# [ ] ENTERPRISE_ACCESS_ALLOW_ENV_SECRET_REFS=false unless explicitly approved
# [ ] DNS records point to production host
# [ ] TLS cert issuance works via Caddy

# =============================================================================
# DNS CONFIGURATION
# =============================================================================
# A       hectic.io          -> <production-server-ip>
# A       admin.hectic.io    -> <production-server-ip>
# A       api.hectic.io      -> <production-server-ip>
# A       *.hectic.io        -> <production-server-ip> (optional for tenant subdomains)
