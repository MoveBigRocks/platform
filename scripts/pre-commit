#!/bin/sh

# Backward-compatible entrypoint for the pre-commit hook.
# Keep scripts as wrappers so both installation paths remain supported.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
HOOK_SCRIPT="$SCRIPT_DIR/../.githooks/pre-commit"

if [ -f "$HOOK_SCRIPT" ]; then
  exec "$HOOK_SCRIPT"
fi

# If the canonical hook is not present, keep behavior permissive.
exit 0
