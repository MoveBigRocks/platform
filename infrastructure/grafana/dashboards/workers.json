{
  "uid": "mbr-workers",
  "title": "Workers",
  "tags": ["mbr", "workers"],
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "title": "CPU Usage", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{"expr": "rate(process_cpu_seconds_total[5m])", "legendFormat": "CPU", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "id": 2, "title": "Process Memory", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{"expr": "process_resident_memory_bytes", "legendFormat": "RSS", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 3, "title": "Open File Descriptors", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {"expr": "process_open_fds", "legendFormat": "open", "refId": "A"},
        {"expr": "process_max_fds", "legendFormat": "max", "refId": "B"}
      ]
    },
    {
      "id": 4, "title": "GC Duration", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{"expr": "rate(go_gc_duration_seconds_sum[5m])", "legendFormat": "GC", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ],
  "schemaVersion": 39
}
