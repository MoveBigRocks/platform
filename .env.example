# Server Configuration
PORT=8080
ENVIRONMENT=development

# Domain Configuration (auto-generates all subdomain URLs)
# Development: defaults to "lvh.me" for local subdomain testing
# Production:  set to "mbr.example.com"
# DOMAIN=mbr.example.com  # Uncomment to override

# Database Configuration (PostgreSQL)
# Move Big Rocks runs on PostgreSQL in local development and production.
# If DATABASE_DSN is left unset here, `make run` defaults to:
# postgres://$USER@127.0.0.1:5432/postgres?sslmode=disable
# Example explicit local DSN:
# DATABASE_DSN=postgres://postgres:postgres@127.0.0.1:5432/mbr_dev?sslmode=disable
# Optional database pool tuning for concurrent outbox and async workers
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m
DATABASE_CONN_MAX_IDLE_TIME=5m

# Storage Configuration
STORAGE_TYPE=filesystem
STORAGE_PATH=./data

# S3/Spaces Configuration (for attachments)
# S3_REGION=us-east-1
# S3_ENDPOINT=https://ams3.digitaloceanspaces.com
# S3_ATTACHMENTS_BUCKET=mbr-attachments
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Cache (filesystem-based)
CACHE_ENABLED=true
CACHE_TTL=1h

# Authentication
# CRITICAL: Generate a strong random secret for production
# Generate with: openssl rand -base64 64
JWT_SECRET=dev-only-insecure-jwt-secret-REPLACE-IN-PRODUCTION
JWT_EXPIRY=24h
MAGIC_LINK_TTL=15m
# Production extension trust should always be bound to a stable instance identity.
# INSTANCE_ID=mbr-prod-001
# EXTENSION_TRUST_REQUIRE_VERIFICATION=true
# EXTENSION_TRUSTED_PUBLISHERS_JSON={"demandops":{"ed25519:prod":"REPLACE_WITH_PRODUCTION_PUBLISHER_KEY"}}
# Cookie domain for cross-subdomain auth
# Production: set to ".mbr.example.com" (note leading dot)
# Development: leave empty for host-only cookies
# COOKIE_DOMAIN=.mbr.example.com

# Privileged identity policy (production defaults tighten these automatically)
# ENTERPRISE_ACCESS_ALLOWED_HOSTS=login.microsoftonline.com,*.okta.com
# ENTERPRISE_ACCESS_ALLOW_ENV_SECRET_REFS=false

# Email Configuration
EMAIL_BACKEND=mock  # Options: mock, postmark, smtp, ses, sendgrid
# Recommended production default: postmark
# POSTMARK_SERVER_TOKEN=
# POSTMARK_WEBHOOK_SECRET=
# SES_REGION=
# SES_ACCESS_KEY=
# SES_SECRET_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MIN=60

# Distributed Tracing (optional)
TRACING_ENABLED=false
TRACING_SAMPLE_RATE=0.01
